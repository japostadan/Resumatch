{
  "name": "resumatch-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx/esm src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "lint": "oxlint src",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@resumatch/shared": "*",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
