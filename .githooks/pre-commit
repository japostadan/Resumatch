#!/bin/sh
# Auto-format staged files with oxfmt before they're committed, so a
# misconfigured editor (e.g. one that saves Prettier-style semicolons and
# double quotes) can't slip unformatted code past the CI format:check.
#
# Installed via `core.hooksPath` (see the root package.json "prepare" script);
# no husky. lint-staged runs oxfmt only on staged files and safely stashes any
# unstaged changes while it does.
npx --no-install lint-staged
